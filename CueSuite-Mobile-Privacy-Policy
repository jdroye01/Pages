    .info-box.green { background: var(--green-bg); border: 1px solid var(--green-bdr); color: var(--ink-soft); }
    .info-box.blue  { background: var(--blue-bg);  border: 1px solid var(--blue-bdr);  color: var(--ink-soft); }
    .info-box-icon  { flex-shrink: 0; font-size: 1.1rem; }

    .toc {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 14px;
